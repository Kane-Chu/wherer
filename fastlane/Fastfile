default_platform(:ios)

require "json"

platform :ios do
  desc "Run tests"
  lane :test do
    scan(
      scheme: "Wherer",
      destination: ENV["SCAN_DESTINATION"] || "platform=iOS Simulator,id=#{discover_test_simulator_id}",
      clean: true
    )
  end

  desc "Build archive (Release)"
  lane :build do
    gym(
      scheme: "Wherer",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "Wherer.ipa",
      clean: true,
      include_bitcode: false
    )
  end

  desc "Upload to TestFlight (internal testing)"
  lane :beta do
    # 1. 运行测试
    test

    # 2. 构建
    build

    # 3. 上传到 TestFlight
    upload_to_testflight(
      ipa: "build/Wherer.ipa",
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )

    UI.success("✅ 已上传到 TestFlight，请前往 App Store Connect 查看")
  end

  desc "Build and upload to App Store Connect (production)"
  lane :release do
    # 1. 确保在 main 分支且没有未提交更改
    ensure_git_status_clean
    ensure_git_branch(branch: "main")
    validate_release_state

    # 2. 运行测试
    test

    # 3. 读取版本号
    version = get_version_number(xcodeproj: "Wherer.xcodeproj")
    build_number = increment_build_number(xcodeproj: "Wherer.xcodeproj")

    UI.important("🚀 发布版本: #{version} (Build #{build_number})")

    # 4. 构建
    build

    # 5. 上传到 App Store
    upload_to_app_store(
      ipa: "build/Wherer.ipa",
      force: true,          # 跳过 HTML 报告
      skip_metadata: true,  # 不修改元数据
      skip_screenshots: true # 不上传截图
    )

    UI.success("✅ 已上传到 App Store Connect")
    UI.message("请前往 https://appstoreconnect.apple.com 提交审核")
  end

  desc "Generate App Store screenshots"
  lane :screenshots do
    devices = discover_screenshot_simulators
    output_dir = "fastlane/screenshots"

    # 清空旧截图
    FileUtils.rm_rf(output_dir)
    FileUtils.mkdir_p(output_dir)

    devices.each do |device_name, udid|
      UI.message("📱 正在使用 #{device_name} 截图...")

      # 启动模拟器
      sh("xcrun simctl boot #{udid} 2>/dev/null || true")

      # 直接用 xcodebuild 运行 UI 测试，绕过 scan 的 showBuildSettings 超时问题
      sh("cd .. && xcodebuild test -scheme Wherer -project Wherer.xcodeproj -configuration Release -destination 'platform=iOS Simulator,id=#{udid}' -only-testing:WhererUITests/WhererUITests/testScreenshots")

      # 从模拟器提取截图
      extract_screenshots(udid: udid, device_name: device_name, output_dir: output_dir)
    end

    # 调整截图尺寸到 App Store 标准
    resize_screenshots_for_app_store(output_dir: output_dir)

    # 生成 HTML 预览
    generate_screenshots_html(output_dir: output_dir)

    UI.success("✅ 截图已保存到 #{output_dir}/")
  end

  desc "Check build status on App Store Connect"
  lane :check_build_status do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: File.join(Dir.pwd, ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    )

    Spaceship::ConnectAPI.login(api_key: api_key)
    app = Spaceship::ConnectAPI::App.find("com.kane.wherer")
    builds = app.get_builds(sort: "-uploadedDate", limit: 5)

    UI.message("")
    UI.success("📦 Build 状态查询结果")
    UI.message("-" * 50)

    builds.each do |build|
      version = build.app_version
      build_num = build.version
      state = build.processing_state
      uploaded = build.uploaded_date

      state_icon = case state
                   when "VALID" then "✅"
                   when "PROCESSING" then "⏳"
                   when "INVALID" then "❌"
                   else "❓"
                   end

      UI.message("#{state_icon} Build #{version} (#{build_num}) - #{state} - #{uploaded}")
    end

    UI.message("-" * 50)
  end

  desc "Upload metadata to App Store Connect"
  lane :upload_metadata_only do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: File.join(Dir.pwd, ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    )

    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: true,
      force: true,
      overwrite_screenshots: false,
      run_precheck_before_submit: false,
      submit_for_review: false
    )

    UI.success("✅ Metadata 已上传到 App Store Connect")
  end

  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots_only do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
      key_filepath: File.join(Dir.pwd, ENV["APP_STORE_CONNECT_API_KEY_PATH"])
    )

    upload_to_app_store(
      api_key: api_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      force: true,
      overwrite_screenshots: true,
      run_precheck_before_submit: false
    )

    UI.success("✅ 截图已上传到 App Store Connect")
  end

  desc "Increment build number and commit"
  lane :bump do
    increment_build_number(xcodeproj: "Wherer.xcodeproj")
    build_number = get_build_number(xcodeproj: "Wherer.xcodeproj")

    git_add(path: "Wherer.xcodeproj/project.pbxproj")
    git_commit(path: "Wherer.xcodeproj/project.pbxproj", message: "chore: bump build number to #{build_number}")

    UI.success("✅ Build number bumped to #{build_number}")
  end

  # ========== 私有方法 ==========

  private_lane :validate_release_state do
    version = get_version_number(xcodeproj: "Wherer.xcodeproj")
    build_number = get_build_number(xcodeproj: "Wherer.xcodeproj")
    root = File.expand_path("..", __dir__)
    changelog = File.read(File.join(root, "CHANGELOG.md"))
    readme = File.read(File.join(root, "README.md"))

    UI.user_error!("MARKETING_VERSION 必须是 vX.Y.Z 对应的三段数字，当前为 #{version}") unless version.match?(/^\d+\.\d+\.\d+$/)
    UI.user_error!("CURRENT_PROJECT_VERSION 必须是正整数，当前为 #{build_number}") unless build_number.to_s.match?(/^[1-9]\d*$/)
    UI.user_error!("CHANGELOG.md 缺少 ## v#{version} 版本段") unless changelog.include?("## v#{version}")
    UI.user_error!("README.md 缺少 GitHub release badge") unless readme.include?("img.shields.io/github/v/release/Kane-Chu/wherer")

    tag = "v#{version}"
    tag_exists = system("git rev-parse -q --verify refs/tags/#{tag} >/dev/null")
    UI.user_error!("Git tag #{tag} 已存在，请先确认版本号") if tag_exists

    UI.success("✅ Release metadata validated: #{version} (Build #{build_number})")
  end

  private_lane :discover_screenshot_simulators do
    desired_names = ["iPhone 16 Pro Max", "iPhone 16", "iPhone 15 Pro Max", "iPhone 15"]
    raw = Actions.sh("xcrun simctl list devices available --json", log: false)
    payload = JSON.parse(raw)
    devices = payload.fetch("devices", {}).values.flatten
    iphones = devices.select { |device| device["isAvailable"] && device["name"].include?("iPhone") }

    selected = desired_names.filter_map do |name|
      device = iphones.find { |candidate| candidate["name"] == name }
      [name, device["udid"]] if device
    end.to_h

    if selected.empty?
      fallback = iphones.first
      UI.user_error!("未找到可用 iPhone 模拟器，请先在 Xcode 安装 iOS Simulator runtime") unless fallback
      selected[fallback["name"]] = fallback["udid"]
    end

    selected
  end

  private_lane :discover_test_simulator_id do
    discover_screenshot_simulators.values.first
  end

  private_lane :extract_screenshots do |options|
    udid = options[:udid]
    device_name = options[:device_name]
    output_dir = options[:output_dir]

    # 查找 app container
    begin
      container_output = Actions.sh("xcrun simctl get_app_container #{udid} com.kane.wherer data 2>/dev/null || echo ''", log: false)
    rescue
      container_output = ""
    end

    if container_output.strip.empty?
      # 模拟器可能已关闭，尝试直接从文件系统查找
      container_path = Dir.glob("#{ENV['HOME']}/Library/Developer/CoreSimulator/Devices/#{udid}/data/Containers/Data/Application/*/Documents/screenshots").first
    else
      container_path = "#{container_output.strip}/Documents/screenshots"
    end

    if container_path.nil? || !Dir.exist?(container_path)
      UI.error("❌ 找不到截图目录: #{device_name}")
      next
    end

    # 复制截图到输出目录
    device_dir = File.join(output_dir, device_name.gsub(" ", ""))
    FileUtils.mkdir_p(device_dir)

    Dir.glob("#{container_path}/**/*.png").each do |src|
      rel = src.sub("#{container_path}/", "")
      dst = File.join(device_dir, rel)
      FileUtils.mkdir_p(File.dirname(dst))
      FileUtils.cp(src, dst)
      UI.message("   📸 #{rel}")
    end
  end

  private_lane :resize_screenshots_for_app_store do |options|
    output_dir = options[:output_dir]

    # App Store 6.5 英寸竖屏标准尺寸
    target_w = 1284
    target_h = 2778

    Dir.glob("#{output_dir}/**/*.png").each do |path|
      img = MiniMagick::Image.open(path)
      w = img.width
      h = img.height

      next if w == target_w && h == target_h

      # 等比缩放到目标高度，居中裁剪宽度
      img.combine_options do |c|
        c.resize("#{target_w}x#{target_h}^")
        c.gravity("center")
        c.crop("#{target_w}x#{target_h}+0+0")
      end
      img.write(path)

      UI.message("   📐 #{File.basename(path)} resized to #{target_w}x#{target_h}")
    end
  end

  private_lane :generate_screenshots_html do |options|
    output_dir = options[:output_dir]
    html_path = File.join(output_dir, "screenshots.html")

    screenshots = Dir.glob("#{output_dir}/**/*.png").sort

    rows = screenshots.map do |path|
      rel = path.sub("#{output_dir}/", "")
      name = File.basename(path, ".png")
      %Q{<tr><td>#{name}</td><td><img src="#{rel}" width="300"></td></tr>}
    end.join("\n")

    html = <<~HTML
      <!DOCTYPE html>
      <html>
      <head>
        <meta charset="utf-8">
        <title>App Store Screenshots</title>
        <style>
          body { font-family: -apple-system, sans-serif; margin: 20px; background: #f5f5f5; }
          h1 { font-size: 24px; margin-bottom: 20px; }
          table { border-collapse: collapse; width: 100%; background: white; }
          th, td { padding: 12px; text-align: left; border-bottom: 1px solid #ddd; }
          th { background: #333; color: white; }
          img { border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        </style>
      </head>
      <body>
        <h1>App Store Screenshots</h1>
        <table>
          <tr><th>名称</th><th>预览</th></tr>
          #{rows}
        </table>
      </body>
      </html>
    HTML

    File.write(html_path, html)
    UI.message("📝 预览文件: #{html_path}")
  end
end
